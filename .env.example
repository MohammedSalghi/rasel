# =====================================================================
# مصرف النوران — Al-Nouran Bank | Environment variables (example)
# Copy this file to `.env` for local development, and configure the same
# keys inside Netlify → Site settings → Environment variables for prod.
# =====================================================================

# --- Public (exposed to the browser) --------------------------------
# Anything prefixed with VITE_ is inlined into the client bundle.
# NEVER put secrets here.
VITE_APP_NAME="مصرف النوران"
VITE_APP_SHORT_NAME="Al-Nouran Bank"
VITE_APP_URL="https://app.alnouran.ly"
VITE_SUPPORT_EMAIL="support@alnouran.ly"

# --- Server-only (available inside server functions / SSR) ----------
# These are NOT exposed to the browser. Do not prefix with VITE_.
# API_BASE_URL="https://api.alnouran.ly"
# API_TOKEN=""                # backend service token
# JWT_SECRET=""               # session signing secret
# DATABASE_URL=""             # postgres connection string
# SMTP_HOST=""
# SMTP_USER=""
# SMTP_PASSWORD=""

# --- Build target ---------------------------------------------------
# On Netlify this is set inside netlify.toml. Uncomment only when
# building for Netlify from a local terminal.
# NITRO_PRESET="netlify"
